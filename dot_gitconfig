[include]
	path = ~/.config/delta/catppuccin.gitconfig
	path = ~/.gitconfig.local
[alias]
	co = checkout
	br = branch
	ci = commit
	st = status
	unstage = reset HEAD --
	last = log -1 HEAD
	uncommit = reset HEAD~1
[init]
	defaultBranch = main
[core]
	editor = nvim
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	features = catppuccin-mocha
	keep-plus-minus-markers = true
[merge]
	conflictStyle = zdiff3
[pull]
	rebase = true
