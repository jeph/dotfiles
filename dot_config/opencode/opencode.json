{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "provider": {
    "amazon-bedrock": {
      "options": {
        "profile": "default",
        "region": "us-east-2"
      }
    }
  },
  "permission": {
    "bash": {
      "rm *": "ask",
      "rmdir *": "ask",
      "mv *": "ask",
      "dd *": "deny"
    },
    "external_directory": {
      "~/.config/**": "allow",
      "~/.zshrc": "allow",
      "~/.gitconfig": "allow",
      "~/.zshrc.local": "allow",
      "~/.gitconfig.local": "allow",
      "~/.tmux/**": "allow",
      "~/.tmux.conf": "allow",
      "~/Developer/**": "allow"
    }
  },
  "mcp": {
    "brave-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@brave/brave-search-mcp-server",
        "--transport",
        "stdio"
      ],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_SEARCH_API_KEY}"
      },
      "enabled": true
    }
  }
}
